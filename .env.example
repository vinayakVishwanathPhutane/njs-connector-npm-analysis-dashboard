# NPM Analytics Dashboard - Environment Variables

# Application Configuration
NODE_ENV=production
PORT=3000

# Git User Configuration (required for git operations)
GIT_USER_NAME=NPM Analytics Bot
GIT_USER_EMAIL=bot@example.com

# Git Authentication - Option 1: Personal Access Token (RECOMMENDED)
# Generate a token at: https://github.com/settings/tokens
# Required scopes: repo (for private repos) or public_repo (for public repos only)
GIT_TOKEN=your_github_personal_access_token_here
GIT_USERNAME=your_github_username

# Git Authentication - Option 2: Username/Password (LEGACY - Not recommended)
# Note: GitHub deprecated password authentication. Use Personal Access Token instead.
# GIT_PASSWORD=your_password_here

# Instructions:
# 1. Copy this file to .env
# 2. Replace the placeholder values with your actual credentials
# 3. Never commit the .env file to version control
# 4. For GitHub: Create a Personal Access Token at https://github.com/settings/tokens
# 5. For GitLab: Create a Personal Access Token at https://gitlab.com/-/profile/personal_access_tokens